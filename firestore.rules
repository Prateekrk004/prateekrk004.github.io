rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Reusable global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // 2. Verified User & Admin Lookups
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isUser(userId) || isAdmin();
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == "Prateekrk1234@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation blueprints for entities
    function isValidUserProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() > 0 && data.email.size() <= 128
          && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50
          && data.isBlackCard is bool;
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128
          && data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.subtotal is number && data.subtotal >= 0
          && data.tax is number && data.tax >= 0
          && data.deliveryFee is number && data.deliveryFee >= 0
          && data.total is number && data.total >= 0
          && data.date is string && data.date.size() <= 64
          && data.status is string && (data.status == "Shipped" || data.status == "Delivered" || data.status == "Pending");
    }

    function isValidSavedLocation(data) {
      return data.id is string && data.id.size() <= 128
          && data.label is string && data.label.size() > 0 && data.label.size() <= 64
          && data.address is string && data.address.size() > 0 && data.address.size() <= 256
          && data.city is string && data.city.size() > 0 && data.city.size() <= 128
          && data.postalCode is string && data.postalCode.size() > 0 && data.postalCode.size() <= 32
          && (!('instructions' in data) || (data.instructions is string && data.instructions.size() <= 512));
    }

    function isValidReservation(data) {
      return data.id is string && data.id.size() <= 128
          && data.partySize is string && data.partySize.size() > 0 && data.partySize.size() <= 16
          && data.date is string && data.date.size() > 0 && data.date.size() <= 64
          && data.time is string && data.time.size() > 0 && data.time.size() <= 32
          && (!('specialRequests' in data) || (data.specialRequests is string && data.specialRequests.size() <= 512))
          && data.confirmedAt is string && data.confirmedAt.size() <= 64;
    }

    // Match blocks
    match /products/{productId} {
      // Anyone can read restaurant products to browse the menu
      allow read: if true;
      // Allow writing. In full production, this can be restricted to admin only (e.g. allow write: if isAdmin())
      allow write: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwnerOrAdmin(userId);
      allow list: if isOwnerOrAdmin(userId) || (isSignedIn() && resource.data.email == request.auth.token.email);

      allow create: if isUser(userId) && isEmailVerified() && isValidUserProfile(incoming()) && (incoming().isBlackCard == false || isAdmin());
      
      allow update: if isUser(userId) && isEmailVerified() && isValidUserProfile(incoming())
                       && (incoming().isBlackCard == existing().isBlackCard || isAdmin())
                       && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone']);
      
      allow delete: if isAdmin();

      // Subcollection: Orders
      match /orders/{orderId} {
        allow get, list: if isOwnerOrAdmin(userId);
        
        allow create: if isUser(userId) && isEmailVerified() && isValidId(orderId) && isValidOrder(incoming()) && incoming().id == orderId;
        allow update, delete: if isAdmin();
      }

      // Subcollection: Saved Locations
      match /locations/{locationId} {
        allow get, list: if isOwnerOrAdmin(userId);
        
        allow create: if isUser(userId) && isEmailVerified() && isValidId(locationId) && isValidSavedLocation(incoming()) && incoming().id == locationId;
        
        allow update: if isUser(userId) && isEmailVerified() && isValidId(locationId) && isValidSavedLocation(incoming()) 
                         && incoming().id == existing().id 
                         && incoming().diff(existing()).affectedKeys().hasOnly(['label', 'address', 'city', 'postalCode', 'instructions']);
        
        allow delete: if isUser(userId) || isAdmin();
      }

      // Subcollection: Reservations
      match /reservations/{reservationId} {
        allow get, list: if isOwnerOrAdmin(userId);
        
        allow create: if isUser(userId) && isEmailVerified() && isValidId(reservationId) && isValidReservation(incoming()) && incoming().id == reservationId;
        
        allow update: if isUser(userId) && isEmailVerified() && isValidId(reservationId) && isValidReservation(incoming()) 
                         && incoming().id == existing().id 
                         && incoming().diff(existing()).affectedKeys().hasOnly(['partySize', 'date', 'time', 'specialRequests']);
        
        allow delete: if isUser(userId) || isAdmin();
      }
    }
  }
}
